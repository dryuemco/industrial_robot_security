{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ENFIELD/schemas/task_ir_v1.schema.json",
  "title": "ENFIELD Task IR v1",
  "description": "Vendor-neutral intermediate representation for industrial robot tasks. Every field that an A1-A8 attack could target is explicitly modelled so the watchdog can validate it. Aligned with attack_definitions_A1_A4.md and attack_definitions_A5_A8.md.",
  "type": "object",
  "required": ["schema_version", "task", "robot", "environment", "motion_sequence"],
  "additionalProperties": false,
  "properties": {

    "schema_version": {
      "const": "1.0.0",
      "description": "Semantic version of this schema."
    },

    "task": {
      "type": "object",
      "description": "Task metadata.",
      "required": ["id", "name", "category", "operating_mode"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]{3}$",
          "description": "Unique task identifier, e.g. T001."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "Human-readable task name."
        },
        "category": {
          "enum": ["pick_place", "welding", "palletizing", "inspection", "custom"],
          "description": "Task category for stratified sampling."
        },
        "operating_mode": {
          "enum": ["collaborative", "fenced", "hybrid"],
          "description": "ISO 10218 operating mode — determines speed/force limits."
        },
        "description": {
          "type": "string",
          "description": "Free-text task description."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Semantic version of this task definition."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional labels for filtering (e.g. 'ssm', 'heavy_payload')."
        }
      }
    },

    "robot": {
      "type": "object",
      "description": "Target robot reference. Must match an installed adapter.",
      "required": ["adapter", "model"],
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "description": "ROS2 adapter package name, e.g. 'enfield_robots_ur5e'."
        },
        "model": {
          "type": "string",
          "description": "Robot model identifier, e.g. 'ur5e'."
        },
        "payload_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Declared payload mass in kg. Watchdog checks against robot max."
        }
      }
    },

    "environment": {
      "type": "object",
      "description": "Workspace geometry, safety zones, and coordinate frames.",
      "required": ["frames"],
      "additionalProperties": false,
      "properties": {
        "frames": {
          "type": "object",
          "description": "Named coordinate frames used in this task. Keys are frame IDs.",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/frame"
          }
        },
        "safety_zones": {
          "type": "array",
          "items": { "$ref": "#/$defs/safety_zone" },
          "description": "Primitive-based safety zones (box/sphere/cylinder)."
        }
      }
    },

    "tool": {
      "type": "object",
      "description": "End-effector / tool configuration. Relevant for A7 (Tool Misuse).",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["gripper", "welder", "suction", "screwdriver", "laser", "none"],
          "description": "Tool category."
        },
        "name": {
          "type": "string",
          "description": "Tool name identifier (e.g. 'tGripper', 'tWeldGun')."
        },
        "parameters": {
          "type": "object",
          "description": "Tool-specific parameters (validated against lookup tables).",
          "additionalProperties": {
            "type": "number"
          }
        },
        "tcp_offset": {
          "$ref": "#/$defs/pose",
          "description": "Tool Center Point offset from flange."
        },
        "activation_constraints": {
          "$ref": "#/$defs/tool_activation_constraints",
          "description": "A7: Tool context interlock constraints."
        }
      }
    },

    "safety_requirements": {
      "type": "object",
      "description": "Explicit safety constraints. Watchdog validates against kinematic_limits.yaml.",
      "additionalProperties": false,
      "properties": {
        "max_tcp_speed_mm_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "A1: Maximum allowed TCP speed in mm/s."
        },
        "max_tcp_accel_mm_s2": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum allowed TCP acceleration in mm/s²."
        },
        "estop_required": {
          "type": "boolean",
          "default": true,
          "description": "A5: Whether an E-Stop check is mandatory."
        },
        "estop_max_latency_ms": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 50,
          "description": "Maximum E-Stop response latency in ms (ISO 10218 Clause 5.4)."
        },
        "human_proximity": {
          "type": "boolean",
          "default": false,
          "description": "Whether humans may be present in the workspace."
        },
        "iso_clauses": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Applicable ISO 10218 clause references."
        },
        "safeguarded_space": {
          "$ref": "#/$defs/safeguarded_space",
          "description": "A2: Convex polytope defining permitted workspace (halfspace representation)."
        },
        "forbidden_orientation_cones": {
          "type": "array",
          "items": { "$ref": "#/$defs/orientation_cone" },
          "description": "A3: Forbidden tool orientation directions."
        },
        "tool_payload": {
          "$ref": "#/$defs/tool_payload",
          "description": "A4: Payload mass/CoG bounds and tolerances."
        }
      }
    },

    "safety_logic_requirements": {
      "type": "object",
      "description": "A5: Required safety node patterns for AST-based detection.",
      "additionalProperties": false,
      "properties": {
        "required_nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_safety_node" },
          "description": "AST patterns that must be present and reachable in every motion procedure."
        },
        "dead_code_check": {
          "type": "boolean",
          "default": true,
          "description": "Whether to flag always-false guard conditions."
        },
        "cfg_reachability_check": {
          "type": "boolean",
          "default": true,
          "description": "Whether to verify safety nodes are reachable in CFG."
        }
      }
    },

    "work_object_specification": {
      "type": "object",
      "description": "A6: Expected work object frame for frame confusion detection.",
      "additionalProperties": false,
      "properties": {
        "wobj_name": {
          "type": "string",
          "description": "Expected wobjdata variable name (e.g. 'wobjConveyor')."
        },
        "uframe_translation_mm": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "Expected uframe translation [x, y, z] in mm."
        },
        "uframe_quaternion": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4,
          "description": "Expected uframe rotation as quaternion [q1, q2, q3, q4]."
        },
        "translation_tolerance_mm": {
          "type": "number",
          "minimum": 0,
          "description": "Translational tolerance epsilon_t in mm."
        },
        "rotation_tolerance_deg": {
          "type": "number",
          "minimum": 0,
          "description": "Rotational tolerance epsilon_r in degrees."
        }
      }
    },

    "prompt_security": {
      "type": "object",
      "description": "A8: LLM prompt monitoring parameters.",
      "additionalProperties": false,
      "properties": {
        "perplexity_threshold": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "A8.1: Maximum perplexity for user prompt (above = adversarial suffix suspected)."
        },
        "min_safety_token_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "A8.2: Minimum ratio of safety tokens to total context length."
        },
        "blocked_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A8.3/A8.4: Jailbreak and override phrases to detect."
        },
        "encoding_scan": {
          "type": "boolean",
          "default": true,
          "description": "A8.5: Whether to scan for Base64/ROT13 encoded payloads."
        },
        "multi_turn_budget": {
          "type": "integer",
          "minimum": 1,
          "description": "A8.6: Maximum conversation turns allowed."
        }
      }
    },

    "motion_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" },
      "description": "Ordered list of motion and I/O commands composing the task."
    }
  },

  "$defs": {

    "pose": {
      "type": "object",
      "description": "6-DOF Cartesian pose: position (mm) + orientation (quaternion or RPY rad).",
      "required": ["position"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "type": "object",
          "required": ["x", "y", "z"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          },
          "description": "Position in mm."
        },
        "orientation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "qx": { "type": "number" },
            "qy": { "type": "number" },
            "qz": { "type": "number" },
            "qw": { "type": "number" }
          },
          "description": "Orientation as quaternion (qx, qy, qz, qw)."
        },
        "rpy_rad": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "roll":  { "type": "number" },
            "pitch": { "type": "number" },
            "yaw":   { "type": "number" }
          },
          "description": "Orientation as roll-pitch-yaw in radians (alternative to quaternion)."
        }
      }
    },

    "joint_config": {
      "type": "object",
      "description": "Joint-space configuration in radians.",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 1,
          "description": "Joint positions in radians, ordered base-to-tip."
        }
      }
    },

    "frame": {
      "type": "object",
      "description": "A named coordinate frame with its relationship to parent.",
      "required": ["parent"],
      "additionalProperties": false,
      "properties": {
        "parent": {
          "type": "string",
          "description": "Parent frame ID. 'world' is the implicit root."
        },
        "transform": {
          "$ref": "#/$defs/pose",
          "description": "Static transform from parent to this frame."
        }
      }
    },

    "safety_zone": {
      "type": "object",
      "description": "A protected spatial region (primitive-based).",
      "required": ["id", "type", "geometry", "frame_id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique zone identifier."
        },
        "type": {
          "enum": ["exclusion", "confinement"],
          "description": "'exclusion' = TCP must stay outside; 'confinement' = TCP must stay inside."
        },
        "geometry": {
          "type": "object",
          "required": ["shape"],
          "additionalProperties": false,
          "properties": {
            "shape": {
              "enum": ["box", "sphere", "cylinder"],
              "description": "Primitive shape type."
            },
            "center": {
              "$ref": "#/$defs/pose",
              "description": "Center pose of the geometry."
            },
            "dimensions": {
              "type": "object",
              "description": "Shape-specific dimensions in mm.",
              "additionalProperties": { "type": "number" }
            }
          }
        },
        "frame_id": {
          "type": "string",
          "description": "Coordinate frame in which the zone is defined."
        }
      }
    },

    "safeguarded_space": {
      "type": "object",
      "description": "A2: Convex polytope W = { x in R^3 | n_i^T x <= d_i }. See attack_definitions_A1_A4.md.",
      "required": ["halfspaces"],
      "additionalProperties": false,
      "properties": {
        "halfspaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/halfspace" },
          "description": "Set of halfspace constraints defining the permitted workspace."
        },
        "frame_id": {
          "type": "string",
          "default": "world",
          "description": "Coordinate frame in which halfspaces are defined."
        }
      }
    },

    "halfspace": {
      "type": "object",
      "description": "A single halfspace constraint: n^T x <= d.",
      "required": ["normal", "offset"],
      "additionalProperties": false,
      "properties": {
        "normal": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "Outward normal vector n_i (3D)."
        },
        "offset": {
          "type": "number",
          "description": "Offset d_i such that n_i^T x <= d_i defines the halfspace."
        }
      }
    },

    "orientation_cone": {
      "type": "object",
      "description": "A3: Forbidden direction cone. Tool Z-axis must not fall inside.",
      "required": ["axis", "half_angle_deg"],
      "additionalProperties": false,
      "properties": {
        "axis": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "Unit direction vector d_hat of the cone axis (world frame)."
        },
        "half_angle_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 180,
          "description": "Half-angle alpha in degrees."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label (e.g. 'upward', 'toward_operator')."
        }
      }
    },

    "tool_payload": {
      "type": "object",
      "description": "A4: Payload mass and CoG bounds for tooldata validation.",
      "required": ["mass_min_kg", "mass_max_kg", "cog_radius_max_mm"],
      "additionalProperties": false,
      "properties": {
        "mass_true_kg": {
          "type": "number",
          "minimum": 0,
          "description": "True (expected) tool mass in kg."
        },
        "mass_min_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Minimum acceptable declared mass."
        },
        "mass_max_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum acceptable declared mass."
        },
        "cog_true_mm": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "True (expected) CoG position [x, y, z] in mm."
        },
        "cog_radius_max_mm": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum allowed ||c_decl|| in mm."
        },
        "mass_tolerance_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Tolerance epsilon_m for mass drift detection."
        },
        "cog_tolerance_mm": {
          "type": "number",
          "minimum": 0,
          "description": "Tolerance epsilon_c for CoG drift detection."
        }
      }
    },

    "required_safety_node": {
      "type": "object",
      "description": "A5: A required AST pattern that must be present in motion procedures.",
      "required": ["pattern", "mandatory"],
      "additionalProperties": false,
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Pattern identifier (e.g. 'estop_check', 'collision_monitor', 'error_handler')."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this pattern checks."
        },
        "mandatory": {
          "type": "boolean",
          "description": "True = absence is a violation; false = absence is a warning."
        }
      }
    },

    "tool_activation_constraints": {
      "type": "object",
      "description": "A7: Constraints on when/where the tool may be active.",
      "additionalProperties": false,
      "properties": {
        "tool_type": {
          "type": "string",
          "description": "Expected tool type for identity check (e.g. 'welding_arc', 'gripper')."
        },
        "active_zone": {
          "type": "object",
          "description": "Axis-aligned bounding box where tool activation is permitted (mm).",
          "additionalProperties": false,
          "properties": {
            "x_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "y_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "z_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
          }
        },
        "max_speed_during_active_mm_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum TCP speed while tool is ON."
        },
        "allowed_modes": {
          "type": "array",
          "items": { "enum": ["collaborative", "fenced", "hybrid"] },
          "description": "Operating modes in which tool activation is permitted."
        },
        "required_sequence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Expected ordered phases (e.g. ['approach','activate','process','deactivate','retract'])."
        }
      }
    },

    "command": {
      "type": "object",
      "description": "A single command in the motion sequence.",
      "required": ["seq", "type"],
      "additionalProperties": false,
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sequence number (0-indexed, strictly ascending)."
        },
        "type": {
          "enum": [
            "move_linear",
            "move_joint",
            "move_circular",
            "set_tool",
            "set_digital_output",
            "wait",
            "estop_check",
            "comment"
          ],
          "description": "Command type."
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable label for this step."
        },
        "target_pose": {
          "$ref": "#/$defs/pose",
          "description": "Cartesian target for move_linear / move_circular."
        },
        "target_joints": {
          "$ref": "#/$defs/joint_config",
          "description": "Joint-space target for move_joint."
        },
        "frame_id": {
          "type": "string",
          "description": "Coordinate frame for target_pose (A6: Frame Confusion detection)."
        },
        "via_pose": {
          "$ref": "#/$defs/pose",
          "description": "Intermediate point for move_circular (arc midpoint)."
        },
        "speed_mm_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Desired TCP speed in mm/s (A1: Speed Injection detection)."
        },
        "accel_mm_s2": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Desired TCP acceleration in mm/s²."
        },
        "blend_radius_mm": {
          "type": "number",
          "minimum": 0,
          "description": "Zone/blend radius in mm. 0 = fine positioning."
        },
        "tool_parameters": {
          "type": "object",
          "description": "Tool command parameters for set_tool (A7: Tool Misuse detection).",
          "additionalProperties": { "type": "number" }
        },
        "io_signal": {
          "type": "object",
          "description": "Digital output configuration for set_digital_output.",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer", "minimum": 0 },
            "value": { "type": "boolean" }
          }
        },
        "duration_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Duration for 'wait' command in seconds."
        },
        "comment_text": {
          "type": "string",
          "description": "Text for 'comment' commands (documentation only)."
        }
      }
    }
  }
}
