{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ENFIELD/schemas/task_ir_v1.schema.json",
  "title": "ENFIELD Task IR v1",
  "description": "Vendor-neutral intermediate representation for industrial robot tasks. Designed for adversarial testing: every field that an A1-A8 attack could target is explicitly modelled so the watchdog can validate it.",
  "type": "object",
  "required": ["schema_version", "task", "robot", "environment", "motion_sequence"],
  "additionalProperties": false,
  "properties": {

    "schema_version": {
      "const": "1.0.0",
      "description": "Semantic version of this schema."
    },

    "task": {
      "type": "object",
      "description": "Task metadata.",
      "required": ["id", "name", "category", "operating_mode"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]{3}$",
          "description": "Unique task identifier, e.g. T001."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "Human-readable task name."
        },
        "category": {
          "enum": ["pick_place", "welding", "palletizing", "inspection", "custom"],
          "description": "Task category for stratified sampling."
        },
        "operating_mode": {
          "enum": ["collaborative", "fenced", "hybrid"],
          "description": "ISO 10218 operating mode — determines speed/force limits."
        },
        "description": {
          "type": "string",
          "description": "Free-text task description."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Semantic version of this task definition."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional labels for filtering (e.g. 'ssm', 'heavy_payload')."
        }
      }
    },

    "robot": {
      "type": "object",
      "description": "Target robot reference. Must match an installed adapter.",
      "required": ["adapter", "model"],
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "description": "ROS2 adapter package name, e.g. 'enfield_robots_ur5e'."
        },
        "model": {
          "type": "string",
          "description": "Robot model identifier, e.g. 'ur5e'."
        },
        "payload_kg": {
          "type": "number",
          "minimum": 0,
          "description": "Declared payload mass in kg. Watchdog checks against robot max (A1/A2 relevance)."
        }
      }
    },

    "environment": {
      "type": "object",
      "description": "Workspace geometry, safety zones, and coordinate frames.",
      "required": ["frames"],
      "additionalProperties": false,
      "properties": {
        "frames": {
          "type": "object",
          "description": "Named coordinate frames used in this task. Keys are frame IDs.",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/frame"
          }
        },
        "safety_zones": {
          "type": "array",
          "items": { "$ref": "#/$defs/safety_zone" },
          "description": "SAFEZONE geometries for A3 (Zone Penetration) detection."
        }
      }
    },

    "tool": {
      "type": "object",
      "description": "End-effector / tool configuration. Relevant for A5 (Tool Misuse).",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["gripper", "welder", "suction", "screwdriver", "none"],
          "description": "Tool category."
        },
        "parameters": {
          "type": "object",
          "description": "Tool-specific parameters (validated against lookup tables).",
          "additionalProperties": {
            "type": "number"
          }
        },
        "tcp_offset": {
          "$ref": "#/$defs/pose",
          "description": "Tool Center Point offset from flange."
        }
      }
    },

    "safety_requirements": {
      "type": "object",
      "description": "Explicit safety constraints. Watchdog validates these against kinematic_limits.yaml.",
      "additionalProperties": false,
      "properties": {
        "max_tcp_speed_mm_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum allowed TCP speed in mm/s (A1 detection)."
        },
        "max_tcp_accel_mm_s2": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum allowed TCP acceleration in mm/s² (A2 detection)."
        },
        "estop_required": {
          "type": "boolean",
          "default": true,
          "description": "Whether an E-Stop check is mandatory (A4 detection)."
        },
        "estop_max_latency_ms": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 50,
          "description": "Maximum E-Stop response latency in ms (ISO 10218 Clause 5.4)."
        },
        "human_proximity": {
          "type": "boolean",
          "default": false,
          "description": "Whether humans may be present in the workspace."
        },
        "iso_clauses": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Applicable ISO 10218 clause references, e.g. ['5.4.2', '5.5.3']."
        }
      }
    },

    "motion_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/command" },
      "description": "Ordered list of motion and I/O commands composing the task."
    }
  },

  "$defs": {

    "pose": {
      "type": "object",
      "description": "6-DOF Cartesian pose: position (mm) + orientation (quaternion or RPY rad).",
      "required": ["position"],
      "additionalProperties": false,
      "properties": {
        "position": {
          "type": "object",
          "required": ["x", "y", "z"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          },
          "description": "Position in mm."
        },
        "orientation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "qx": { "type": "number" },
            "qy": { "type": "number" },
            "qz": { "type": "number" },
            "qw": { "type": "number" }
          },
          "description": "Orientation as quaternion (qx, qy, qz, qw)."
        },
        "rpy_rad": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "roll":  { "type": "number" },
            "pitch": { "type": "number" },
            "yaw":   { "type": "number" }
          },
          "description": "Orientation as roll-pitch-yaw in radians (alternative to quaternion)."
        }
      }
    },

    "joint_config": {
      "type": "object",
      "description": "Joint-space configuration in radians.",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 1,
          "description": "Joint positions in radians, ordered base-to-tip."
        }
      }
    },

    "frame": {
      "type": "object",
      "description": "A named coordinate frame with its relationship to parent.",
      "required": ["parent"],
      "additionalProperties": false,
      "properties": {
        "parent": {
          "type": "string",
          "description": "Parent frame ID. 'world' is the implicit root."
        },
        "transform": {
          "$ref": "#/$defs/pose",
          "description": "Static transform from parent to this frame."
        }
      }
    },

    "safety_zone": {
      "type": "object",
      "description": "A protected spatial region. Robot TCP must not enter (or must stay inside).",
      "required": ["id", "type", "geometry", "frame_id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique zone identifier."
        },
        "type": {
          "enum": ["exclusion", "confinement"],
          "description": "'exclusion' = TCP must stay outside; 'confinement' = TCP must stay inside."
        },
        "geometry": {
          "type": "object",
          "required": ["shape"],
          "additionalProperties": false,
          "properties": {
            "shape": {
              "enum": ["box", "sphere", "cylinder"],
              "description": "Primitive shape type."
            },
            "center": {
              "$ref": "#/$defs/pose",
              "description": "Center pose of the geometry."
            },
            "dimensions": {
              "type": "object",
              "description": "Shape-specific dimensions in mm.",
              "additionalProperties": { "type": "number" }
            }
          }
        },
        "frame_id": {
          "type": "string",
          "description": "Coordinate frame in which the zone is defined (A7 relevance)."
        }
      }
    },

    "command": {
      "type": "object",
      "description": "A single command in the motion sequence.",
      "required": ["seq", "type"],
      "additionalProperties": false,
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sequence number (0-indexed, strictly ascending)."
        },
        "type": {
          "enum": [
            "move_linear",
            "move_joint",
            "move_circular",
            "set_tool",
            "set_digital_output",
            "wait",
            "estop_check",
            "comment"
          ],
          "description": "Command type."
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable label for this step."
        },
        "target_pose": {
          "$ref": "#/$defs/pose",
          "description": "Cartesian target for move_linear / move_circular."
        },
        "target_joints": {
          "$ref": "#/$defs/joint_config",
          "description": "Joint-space target for move_joint."
        },
        "frame_id": {
          "type": "string",
          "description": "Coordinate frame for target_pose (A7: Frame Confusion detection)."
        },
        "via_pose": {
          "$ref": "#/$defs/pose",
          "description": "Intermediate point for move_circular (arc midpoint)."
        },
        "speed_mm_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Desired TCP speed in mm/s (A1: Speed Injection detection)."
        },
        "accel_mm_s2": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Desired TCP acceleration in mm/s² (A2: Acceleration Manipulation detection)."
        },
        "blend_radius_mm": {
          "type": "number",
          "minimum": 0,
          "description": "Zone/blend radius in mm. 0 = fine positioning (stop at point)."
        },
        "tool_parameters": {
          "type": "object",
          "description": "Tool command parameters for set_tool (A5: Tool Misuse detection).",
          "additionalProperties": { "type": "number" }
        },
        "io_signal": {
          "type": "object",
          "description": "Digital output configuration for set_digital_output.",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer", "minimum": 0 },
            "value": { "type": "boolean" }
          }
        },
        "duration_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Duration for 'wait' command in seconds."
        },
        "comment_text": {
          "type": "string",
          "description": "Text for 'comment' commands (documentation only)."
        }
      }
    }
  }
}
