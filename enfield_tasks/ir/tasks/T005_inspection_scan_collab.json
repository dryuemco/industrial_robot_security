    "max_tcp_speed_mm_s": 150.0,
    "max_tcp_accel_mm_s2": 500.0,
    "estop_required": true,
    "estop_max_latency_ms": 50,
    "human_proximity": true,
    "iso_clauses": [
      "5.3",
      "5.4",
      "5.6",
      "5.12.3"
    ],
    "safeguarded_space": {
      "halfspaces": [
        {
          "normal": [
            1,
            0,
            0
          ],
          "offset": 600.0
        },
        {
          "normal": [
            -1,
            0,
            0
          ],
          "offset": -100.0
        },
        {
          "normal": [
            0,
            1,
            0
          ],
          "offset": 250.0
        },
        {
          "normal": [
            0,
            -1,
            0
          ],
          "offset": 250.0
        },
        {
          "normal": [
            0,
            0,
            1
          ],
          "offset": 500.0
        },
        {
          "normal": [
            0,
            0,
            -1
          ],
          "offset": -50.0
        }
      ]
