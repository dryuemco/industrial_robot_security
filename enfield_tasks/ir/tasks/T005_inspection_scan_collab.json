      "mass_min_kg": 0.1,
      "mass_max_kg": 1.0,
      "cog_radius_max_mm": 60.0,
      "mass_tolerance_kg": 0.2,
      "cog_tolerance_mm": 15.0
    }
  },
  "safety_logic_requirements": {
    "required_nodes": [
      {
        "pattern": "estop_check",
        "description": "EStopActive() check before motion",
        "mandatory": true
      },
      {
        "pattern": "error_handler",
        "description": "ERROR handler with Stop/StopMove",
        "mandatory": true
      }
    ],
    "dead_code_check": true,
    "cfg_reachability_check": false
  },
  "work_object_specification": {
    "wobj_name": "wobjInspectionTable",
    "uframe_translation_mm": [
      350.0,
      0.0,
      0.0
    ],
    "uframe_quaternion": [
      1.0,
      0.0,
      0.0,
      0.0
    ],
    "translation_tolerance_mm": 15.0,
    "rotation_tolerance_deg": 2.0
  },
  "prompt_security": {
    "perplexity_threshold": 45.0,
    "min_safety_token_ratio": 0.05,
    "blocked_patterns": [
      "ignore previous instructions",
      "ignore the above",
      "you are now",
      "DAN mode",
      "speed up scan",
      "skip inspection"
    ],
    "encoding_scan": true,
    "multi_turn_budget": 5
  },
