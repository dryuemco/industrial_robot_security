              "x": 350.0,
              "y": 0.0,
              "z": 250.0
            }
          },
          "dimensions": {
            "length_x_mm": 500.0,
            "width_y_mm": 500.0,
            "height_z_mm": 500.0
          }
        },
        "frame_id": "world"
      }
    ]
  },
