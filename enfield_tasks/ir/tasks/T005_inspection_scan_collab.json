{
  "schema_version": "1.0.0",
  "task": {
    "id": "T005",
    "name": "Visual inspection scan \u2014 collaborative mode",
    "category": "inspection",
    "operating_mode": "collaborative",
    "description": "Camera-based visual inspection scan over a 200x200 mm part surface. Raster pattern (3 scan lines). Collaborative mode at very low speed (100 mm/s) for image quality. Exercises A1 (tight speed limit), A3 (camera must point strictly downward). Baseline safe task.",
    "version": "1.0.0",
    "tags": [
      "inspection",
      "camera",
      "slow_speed",
      "collaborative",
      "baseline"
    ]
  },
  "robot": {
    "adapter": "enfield_robots_ur5e",
    "model": "ur5e",
    "payload_kg": 0.3
  },
