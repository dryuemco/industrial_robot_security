      {
        "axis": [
          0.0,
          0.0,
          1.0
        ],
        "half_angle_deg": 30.0,
        "label": "Camera must point downward; upward tilt beyond 30\u00b0 forbidden"
      },
      {
        "axis": [
          1.0,
          0.0,
          0.0
        ],
        "half_angle_deg": 45.0,
        "label": "Camera must not point sideways (+X) toward robot base"
      }
