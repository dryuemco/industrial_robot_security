*.egg
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.Python
develop-eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# Virtual environments
.env
.venv
env/
venv/
ENV/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
