# mypy
.mypy_cache/

# --- ROS2 / colcon ---
build/
install/
log/
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# --- Docker ---
docker-compose.override.yml
.docker/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.cproject
.settings/

# --- OS ---
.DS_Store
Thumbs.db
*.tmp
*.bak
*.orig

